PORT=8000
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_service_role_key
REDIS_URL=redis://redis:6379
STRIPE_SECRET_KEY=your_stripe_secret

# OpenAI (Ezri agent responses + TTS)
OPENAI_API_KEY=your_openai_api_key
# Chat model for /api/v1/chat and WS replies
OPENAI_MODEL=gpt-4.1-mini
# TTS model/voice for /api/v1/speak
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral
OPENAI_TTS_FORMAT=mp3

# Allow web dev server origin (CORS)
WEB_ORIGIN=http://localhost:5173

# If enabled, WS replies also include a binary audio frame (TTS)
EZRI_WS_AUDIO=1

# Groq (chat when provider=groq)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# RunPod serverless TTS (when tts_provider=pocket_tts)
RUNPOD_API_KEY=your_runpod_api_key
RUNPOD_TTS_ENDPOINT_ID=your_tts_endpoint_id
