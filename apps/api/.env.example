PORT=3001
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_JWT_SECRET=your_jwt_secret
STRIPE_SECRET_KEY=your_stripe_secret
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
REDIS_URL=redis://redis:6379
AI_SERVICE_URL=http://ai:8000
WEB_BASE_URL=http://localhost:5173

# Email (transactional mail from the API — admin "email user", verification, etc.)
# SMTP_USER must be allowed to send; SMTP_FROM is the visible From (use a product address if your host allows):
# SMTP_FROM="MeetEzri <noreply@meetezri.health>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
