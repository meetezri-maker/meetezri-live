VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_API_URL=http://localhost:3001/api
# Base URL used for Supabase email verification redirects.
# - Local: http://localhost:5173
# - Production: https://meetezri-live-web.vercel.app
VITE_WEB_BASE_URL=http://localhost:5173

# Ezri AI Agent (REST + WebSocket)
VITE_EZRI_API_BASE=http://localhost:8000
# Optional override; if omitted, ws base is derived from api base.
# Local:
# VITE_EZRI_WS_BASE=ws://localhost:8000/api/v1/ws/active
# HuggingFace Space (your deployed backend):
# VITE_EZRI_API_BASE=https://meetezri-ezri-ai-agent.hf.space
# VITE_EZRI_WS_BASE=wss://meetezri-ezri-ai-agent.hf.space/api/v1/ws/active

# Defaults (can later be user-selectable)
VITE_DEFAULT_BRAIN_PROVIDER=groq
VITE_DEFAULT_TTS_PROVIDER=pocket_tts
VITE_DEFAULT_STT_PROVIDER=browser

